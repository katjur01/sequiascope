
# Kombinovaný kontejner pro IGV Desktop snapshoty + statický server
FROM openjdk:17-slim

WORKDIR /srv/igv-static

# Systémové závislosti pro IGV Desktop + Node.js + Xvfb
RUN apt-get update && apt-get install -y --no-install-recommends \
    wget \
    unzip \
    xvfb \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Instalace Node.js (verze 22)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Instalace http-server
RUN npm install -g http-server

# Stažení a instalace IGV Desktop 2.16.2
RUN wget https://data.broadinstitute.org/igv/projects/downloads/2.16/IGV_2.16.2.zip \
    && unzip IGV_2.16.2.zip -d /opt/ \
    && rm IGV_2.16.2.zip \
    && chmod +x /opt/IGV_2.16.2/igv.sh

# Vytvoření skriptu pro spuštění obou služeb
RUN echo '#!/bin/bash\n\
# Spusť Xvfb na pozadí (pro headless IGV)\n\
Xvfb :99 -screen 0 1024x768x24 &\n\
export DISPLAY=:99\n\
\n\
# Spusť http-server na pozadí\n\
http-server /srv/igv-static -p 8081 --cors --no-cache &\n\
\n\
# Udrž kontejner běžící\n\
tail -f /dev/null\n\
' > /start.sh && chmod +x /start.sh

EXPOSE 8081

CMD ["/start.sh"]


