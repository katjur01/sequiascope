
# Kombinovaný kontejner pro IGV Desktop snapshoty + statický server
FROM openjdk:17.0.1-jdk-slim

# Default output directory (can be overridden via environment variable)
ENV OUTPUT_BASE_DIR=/output_files
# K8s sets runAsUser: 1000, but /etc/passwd has no entry for uid=1000 so Java
# falls back to the HOME env var for user.home. JAVA_TOOL_OPTIONS makes it
# explicit: Java will use /root for prefs + igv dirs regardless of /etc/passwd.
ENV HOME=/root
ENV JAVA_TOOL_OPTIONS="-Duser.home=/root"

WORKDIR /app

# Systémové závislosti pro IGV Desktop + Node.js + Xvfb
RUN apt-get update && apt-get install -y --no-install-recommends \
    wget \
    unzip \
    xvfb \
    xauth \
    curl \
    ca-certificates \
    bash \
    procps \
    libxrender1 \
    libxtst6 \
    libxi6 \
    libxext6 \
    libx11-6 \
    fontconfig \
    fonts-dejavu-core \
    fonts-dejavu-extra \
    && rm -rf /var/lib/apt/lists/*

# Instalace Node.js (verze 22)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Instalace http-server
RUN npm install -g http-server

# Stažení a instalace IGV Desktop 2.16.2
RUN wget https://data.broadinstitute.org/igv/projects/downloads/2.16/IGV_2.16.2.zip \
    && unzip IGV_2.16.2.zip -d /opt/ \
    && rm IGV_2.16.2.zip \
    && chmod +x /opt/IGV_2.16.2/igv.sh

# Configure fontconfig for headless operation
RUN fc-cache -fv && mkdir -p /root/.fonts

# Pre-create all dirs that IGV + Java need under /root and make them writable
# for uid=1000 (K8s runAsUser).
# - /root/igv          : IGV DirectoryManager main data dir (no dot!)
# - /root/.igv         : legacy IGV preferences dir
# - /root/.java/.userPrefs : Java FileSystemPreferences
# chmod 777 /root so uid=1000 can also create any additional subdirs IGV needs.
RUN chmod 777 /root \
    && mkdir -p /root/igv /root/.igv /root/.java/.userPrefs \
    && chmod -R 777 /root/igv /root/.igv /root/.java

# Create X11 socket directory for Xvfb (needed for non-root containers in Kubernetes)
RUN mkdir -p /tmp/.X11-unix && chmod 1777 /tmp/.X11-unix

# Zkopírovat wrapper skript pro IGV Desktop
COPY igv_wrapper.sh /usr/local/bin/igv_wrapper.sh
RUN chmod +x /usr/local/bin/igv_wrapper.sh

# Zkopírovat watcher skript pro automatické zpracování batch files
COPY igv_batch_watcher.sh /usr/local/bin/igv_batch_watcher.sh
RUN chmod +x /usr/local/bin/igv_batch_watcher.sh

# Vytvoření skriptu pro spuštění http-serveru a watcheru
RUN echo '#!/bin/bash\n\
# Spusť http-server na pozadí (servíruje /input_files pro BAM soubory)\n\
INPUT_DIR="${INPUT_DIR:-/input_files}"\n\
OUTPUT_BASE_DIR="${OUTPUT_BASE_DIR:-/output_files}"\n\
\n\
# Create symlink for Ingress path prefix /igv-static\n\
# Symlink lives at /srv/igv-static (NOT inside the PVC/INPUT_DIR) so it\n\
# never appears as a directory on the user's input_files volume.\n\
mkdir -p /srv\n\
if [ ! -L "/srv/igv-static" ]; then\n\
  echo "Creating symlink: /srv/igv-static -> ${INPUT_DIR}"\n\
  ln -sf "${INPUT_DIR}" /srv/igv-static\n\
  echo "Symlink created:"\n\
  ls -la /srv/ | grep igv-static\n\
else\n\
  echo "Symlink already exists:"\n\
  ls -la /srv/ | grep igv-static\n\
fi\n\
\n\
echo "Starting http-server on port 8081 serving /srv (igv-static -> ${INPUT_DIR})..."\n\
http-server /srv -p 8081 --cors -c 3600 &\n\
HTTP_SERVER_PID=$!\n\
\n\
# ── Startup diagnostics ──────────────────────────────────────────────────\n\
echo "[START] === Container startup diagnostics ==="\n\
echo "[START] Date       : $(date)"\n\
echo "[START] Whoami     : $(whoami 2>/dev/null || echo unknown)"\n\
echo "[START] UID/GID    : $(id)"\n\
echo "[START] HOME       : $HOME"\n\
echo "[START] /root perms:"\n\
ls -la / | grep " root$" || echo "  (cannot read)"\n\
echo "[START] /root/.igv exists  : $(test -d /root/.igv && echo YES || echo NO)"\n\
echo "[START] /root/.igv writable: $(touch /root/.igv/.wtest 2>/dev/null && echo YES && rm -f /root/.igv/.wtest || echo NO)"\n\
echo "[START] /root/.java exists : $(test -d /root/.java && echo YES || echo NO)"\n\
echo "[START] /root/.java writable: $(touch /root/.java/.wtest 2>/dev/null && echo YES && rm -f /root/.java/.wtest || echo NO)"\n\
echo "[START] Java version:"\n\
java -version\n\
echo "[START] IGV script : $(ls -la /opt/IGV_2.16.2/igv.sh 2>/dev/null || echo NOT FOUND)"\n\
echo "[START] Xvfb       : $(which Xvfb 2>/dev/null || echo NOT FOUND)"\n\
echo "[START] /tmp/.X11-unix: $(ls -la /tmp/ | grep X11 || echo not found)"\n\
echo "[START] WATCH_DIR  : ${WATCH_DIR:-/output_files/sessions}"\n\
echo "[START] OUTPUT_BASE_DIR: $OUTPUT_BASE_DIR"\n\
echo "[START] === End diagnostics ==="\n\
# ─────────────────────────────────────────────────────────────────────────\n\
\n\
echo "Watcher script:"\n\
ls -la /usr/local/bin/igv_batch_watcher.sh\n\
\n\
# Spusť IGV batch file watcher (foreground - hlavní proces)\n\
echo "Starting IGV batch file watcher..."\n\
exec /usr/local/bin/igv_batch_watcher.sh\n\
' > /start.sh && chmod +x /start.sh

EXPOSE 8081

CMD ["/start.sh"]


